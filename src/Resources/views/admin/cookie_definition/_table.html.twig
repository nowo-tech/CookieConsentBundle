{% form_theme form with ['bootstrap_5_layout.html.twig'] %}

<div class="table-responsive">
    <table class="table table-striped mb-0 align-middle">
        <thead>
            <tr>
                <th>{{ 'nowo_cookie_consent.admin.cookie_definition.table.name'|trans({}, 'NowoCookieConsentBundle') }}</th>
                <th>{{ 'nowo_cookie_consent.admin.cookie_definition.table.provider'|trans({}, 'NowoCookieConsentBundle') }}</th>
                <th>{{ 'nowo_cookie_consent.admin.cookie_definition.table.purpose'|trans({}, 'NowoCookieConsentBundle') }}</th>
                <th>{{ 'nowo_cookie_consent.admin.cookie_definition.table.category'|trans({}, 'NowoCookieConsentBundle') }}</th>
                <th>{{ 'nowo_cookie_consent.admin.cookie_definition.table.duration'|trans({}, 'NowoCookieConsentBundle') }}</th>
                <th>{{ 'nowo_cookie_consent.admin.cookie_definition.table.allowed_by_default'|trans({}, 'NowoCookieConsentBundle') }}</th>
                <th class="text-end">{{ 'nowo_cookie_consent.admin.cookie_definition.table.actions'|trans({}, 'NowoCookieConsentBundle') }}</th>
            </tr>
        </thead>
        <tbody>
            {% for definition in definitions %}
                {% set translation = definition.findTranslation(app.request.locale) ?? definition.findTranslation('en') %}
                <tr>
                    <td><code>{{ definition.name }}</code></td>
                    <td>{{ translation ? translation.provider : '' }}</td>
                    <td class="small text-secondary">{{ translation ? translation.purpose : '' }}</td>
                    <td>{{ ('nowo_cookie_consent.admin.cookie_definition.category.' ~ definition.category)|trans({}, 'NowoCookieConsentBundle') }}</td>
                    <td>{{ definition.duration }}</td>
                    <td>{{ definition.allowedByDefault ? 'nowo_cookie_consent.admin.cookie_definition.yes'|trans({}, 'NowoCookieConsentBundle') : 'nowo_cookie_consent.admin.cookie_definition.no'|trans({}, 'NowoCookieConsentBundle') }}</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary" href="{{ path('nowo_cookie_consent_cookie_definitions_edit', { configId: config.id, id: definition.id }) }}">{{ 'nowo_cookie_consent.admin.cookie_definition.edit'|trans({}, 'NowoCookieConsentBundle') }}</a>
                        <form method="post" action="{{ path('nowo_cookie_consent_cookie_definitions_delete', { configId: config.id, id: definition.id }) }}" class="d-inline" onsubmit="return confirm('{{ 'nowo_cookie_consent.admin.cookie_definition.delete_confirm'|trans({'%name%': definition.name}, 'NowoCookieConsentBundle')|e('js') }}');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-cookie-definition-' ~ definition.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'nowo_cookie_consent.admin.cookie_definition.delete'|trans({}, 'NowoCookieConsentBundle') }}</button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center text-muted py-4">
                        {{ 'nowo_cookie_consent.admin.cookie_definition.empty'|trans({}, 'NowoCookieConsentBundle') }}
                    </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
