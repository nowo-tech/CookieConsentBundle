{% set bubble_position = position|default(nowo_cookie_consent_preferences_bubble_position()) %}
{% set bubble_border_color = border_color|default(nowo_cookie_consent_preferences_bubble_border_color()) %}
{% set bubble_icon = icon|default(nowo_cookie_consent_preferences_bubble_icon()) %}
<button type="button"
        class="nowo-cookie-consent__preferences-bubble nowo-cookie-consent__preferences-bubble--{{ bubble_position }}"
        data-nowo-open-consent
        aria-label="{{ 'nowo_cookie_consent.preferences_bubble.label'|trans({}, 'NowoCookieConsentBundle') }}"
        title="{{ label|default('nowo_cookie_consent.manage_link'|trans({}, 'NowoCookieConsentBundle')) }}"
        {% if bubble_border_color %}style="--nowo-cc-bubble-accent: {{ bubble_border_color|e('html_attr') }}"{% endif %}>
    <span class="nowo-cookie-consent__preferences-bubble-icon">
        {% if bubble_icon %}
            {{ bubble_icon|raw }}
        {% else %}
            {% include '@NowoCookieConsentBundle/_preferences_bubble_icon_default.html.twig' %}
        {% endif %}
    </span>
</button>
