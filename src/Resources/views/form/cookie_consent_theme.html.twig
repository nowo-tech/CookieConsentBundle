{% use 'form_div_layout.html.twig' %}

{% block choice_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        <div class="nowo-cookie-consent__category" data-nowo-category="{{ name }}">
            <div class="nowo-cookie-consent__category-toggle">
                {% for child in form %}
                    {% if not child.rendered %}
                        {{- form_widget(child) -}}
                        {{- form_label(child, null, {translation_domain: choice_translation_domain}) -}}
                    {% endif %}
                {% endfor %}
            </div>
            <div class="nowo-cookie-consent__category-information">
                <h4 class="nowo-cookie-consent__category-title">{{ ('nowo_cookie_consent.' ~ name ~ '.title')|trans({}, 'NowoCookieConsentBundle') }}</h4>
                <p class="nowo-cookie-consent__category-description">{{ ('nowo_cookie_consent.' ~ name ~ '.description')|trans({}, 'NowoCookieConsentBundle') }}</p>
            </div>
        </div>
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block checkbox_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        <div class="nowo-cookie-consent__category col-3 py-3" data-nowo-category="{{ name }}">
            <div{% with {attr: row_attr|merge({class: (row_attr.class|default('mb-3') ~ ' text-center')|trim})} %}{{ block('attributes') }}{% endwith %}>
                <label class="nowo-cookie-consent__category-title fs-4" for="cookie_consent_{{ name }}">{{ ('nowo_cookie_consent.' ~ name ~ '.title')|trans({}, 'NowoCookieConsentBundle') }}</label>
                <div class="d-flex justify-content-center">
                    <div></div>
                    <div>
                        {{- form_row(form, {
                            attr: {
                                class: 'mt-1 fs-4',
                            },
                            row_attr: {
                                class: 'form-switch',
                            },
                        }) -}}
                    </div>
                    <div></div>
                </div>
            </div>
            <div class="nowo-cookie-consent__category-information px-1">
                <small class="nowo-cookie-consent__category-description"><label for="cookie_consent_{{ name }}">{{ ('nowo_cookie_consent.' ~ name ~ '.description')|trans({}, 'NowoCookieConsentBundle') }}</label></small>
            </div>
        </div>
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block submit_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        {% if 'nowo-cookie-consent__btn--secondary' in attr.class %}
            {%- set attr = attr|merge({class: (attr.class|default('btn') ~ ' btn-primary me-2')|trim}) -%}
        {% else %}
            {%- set attr = attr|merge({class: (attr.class|default('btn') ~ ' btn-secondary me-2')|trim}) -%}
        {% endif %}
        {{ block('button_widget') }}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}
