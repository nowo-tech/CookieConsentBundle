{% use 'tailwind_2_layout.html.twig' %}

{% block choice_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        <div class="nowo-cookie-consent__category" data-nowo-category="{{ name }}">
            <div class="nowo-cookie-consent__category-toggle">
                {% for child in form %}
                    {% if not child.rendered %}
                        {{- form_widget(child) -}}
                        {{- form_label(child, null, {translation_domain: choice_translation_domain}) -}}
                    {% endif %}
                {% endfor %}
            </div>
            <div class="nowo-cookie-consent__category-information">
                <h4 class="nowo-cookie-consent__category-title text-sm font-semibold text-slate-900">{{ ('nowo_cookie_consent.' ~ name ~ '.title')|trans({}, 'NowoCookieConsentBundle') }}</h4>
                <p class="nowo-cookie-consent__category-description text-xs text-slate-500">{{ ('nowo_cookie_consent.' ~ name ~ '.description')|trans({}, 'NowoCookieConsentBundle') }}</p>
            </div>
        </div>
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block checkbox_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        <div class="nowo-cookie-consent__category rounded-lg border border-slate-200 bg-slate-50 p-4" data-nowo-category="{{ name }}">
            <div class="text-center">
                <label class="nowo-cookie-consent__category-title block text-sm font-semibold text-slate-900" for="cookie_consent_{{ name }}">
                    {{ ('nowo_cookie_consent.' ~ name ~ '.title')|trans({}, 'NowoCookieConsentBundle') }}
                </label>
                <div class="mt-3 flex justify-center">
                    {{- form_widget(form, {
                        attr: {
                            class: 'h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500',
                        },
                    }) -}}
                </div>
            </div>
            <div class="nowo-cookie-consent__category-information mt-3 text-center">
                <p class="nowo-cookie-consent__category-description text-xs text-slate-500">
                    <label for="cookie_consent_{{ name }}">{{ ('nowo_cookie_consent.' ~ name ~ '.description')|trans({}, 'NowoCookieConsentBundle') }}</label>
                </p>
            </div>
        </div>
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block submit_row %}
    {% if form.parent is not null and form.parent.vars.name == 'cookie_consent' %}
        {% if 'nowo-cookie-consent__btn--secondary' in attr.class %}
            {%- set attr = attr|merge({class: (attr.class|default('') ~ ' nowo-cookie-consent__btn inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600')|trim}) -%}
        {% else %}
            {%- set attr = attr|merge({class: (attr.class|default('') ~ ' nowo-cookie-consent__btn inline-flex items-center rounded-md bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50')|trim}) -%}
        {% endif %}
        {{ block('button_widget') }}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}
