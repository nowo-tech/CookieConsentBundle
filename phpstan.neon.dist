# PHPStan configuration for Cookie Consent Bundle
# Compatible with PHP 8.1+ and Symfony 6.x / 7.x / 8.x

parameters:
    level: 8
    paths:
        - src
        - tests
    excludePaths:
        - demo/*

includes:
    - phpstan-baseline.neon
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-symfony/rules.neon
    - vendor/phpstan/phpstan-phpunit/extension.neon
    - vendor/phpstan/phpstan-phpunit/rules.neon
    - vendor/nowo-tech/phpstan-frankenphp/extension.neon
    - vendor/nowo-tech/phpstan-frankenphp/ruleset-classic.neon
    - vendor/nowo-tech/phpstan-frankenphp/ruleset-worker.neon
