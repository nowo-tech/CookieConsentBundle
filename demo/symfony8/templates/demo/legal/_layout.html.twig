{% import 'demo/_routes.html.twig' as demo_route %}

{% include 'demo/_nav.html.twig' %}

<main class="container py-5">
    <div class="row justify-content-center">
        <article class="col-lg-9">
            <div class="card shadow-sm">
                <div class="card-body p-4 p-md-5">
                    <p class="text-muted small mb-2">{{ 'demo.legal.updated'|trans }}</p>
                    <h1 class="h3 mb-4">{{ title|trans }}</h1>

                    {% for section in sections %}
                        <section class="mb-4">
                            <h2 class="h5">{{ section.title|trans }}</h2>
                            <p class="mb-0 text-secondary">{{ section.body|trans }}</p>
                        </section>
                    {% endfor %}

                    {% if show_inventory|default(false) %}
                        {% include 'demo/legal/_cookie_inventory.html.twig' %}
                    {% endif %}

                    <hr class="my-4">

                    <nav aria-label="{{ 'demo.legal.related'|trans }}" class="d-flex flex-wrap gap-2">
                        <a class="btn btn-outline-secondary btn-sm" href="{{ demo_route.path('demo_privacy_policy') }}">
                            {{ 'demo.nav.privacy'|trans }}
                        </a>
                        <a class="btn btn-outline-secondary btn-sm" href="{{ demo_route.path('demo_cookie_policy') }}">
                            {{ 'demo.nav.cookies'|trans }}
                        </a>
                        <a class="btn btn-outline-secondary btn-sm" href="{{ demo_route.path('demo_consent_information') }}">
                            {{ 'demo.nav.consent'|trans }}
                        </a>
                        <button type="button" class="btn btn-primary btn-sm" data-cc="show-preferencesModal">
                            {{ 'nowo_cookie_consent.manage_link'|trans({}, 'NowoCookieConsentBundle') }}
                        </button>
                    </nav>
                </div>
            </div>
        </article>
    </div>
</main>
