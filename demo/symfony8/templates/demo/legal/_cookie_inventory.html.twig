{% set inventory = nowo_cookie_consent_cookie_inventory() %}

{% if inventory is not empty %}
    <section class="mb-4">
        <h2 class="h5">{{ 'demo.legal.cookies.inventory.title'|trans }}</h2>
        <p class="text-secondary small">{{ 'demo.legal.cookies.inventory.lead'|trans }}</p>
        <div class="table-responsive mt-3">
            <table class="table table-sm table-bordered align-middle mb-0">
                <caption class="text-start small text-muted">{{ 'nowo_cookie_consent.inventory.caption'|trans({}, 'NowoCookieConsentBundle') }}</caption>
                <thead class="table-light">
                    <tr>
                        <th scope="col">{{ 'nowo_cookie_consent.inventory.name'|trans({}, 'NowoCookieConsentBundle') }}</th>
                        <th scope="col">{{ 'nowo_cookie_consent.inventory.provider'|trans({}, 'NowoCookieConsentBundle') }}</th>
                        <th scope="col">{{ 'nowo_cookie_consent.inventory.purpose'|trans({}, 'NowoCookieConsentBundle') }}</th>
                        <th scope="col">{{ 'demo.cookies.table.category'|trans }}</th>
                        <th scope="col">{{ 'demo.cookies.table.duration'|trans }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for row in inventory %}
                        <tr>
                            <td><code>{{ row.name }}</code></td>
                            <td>{{ row.provider }}</td>
                            <td class="small">{{ row.purpose }}</td>
                            <td>{{ ('demo.cookies.category.' ~ row.category)|trans }}</td>
                            <td>{{ row.duration }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endif %}
