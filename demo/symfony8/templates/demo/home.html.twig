{% extends 'base.html.twig' %}
{% import 'demo/_routes.html.twig' as demo_route %}

{% block title %}{{ 'demo.home.title'|trans }}{% endblock %}

{% block body %}
    {% include 'demo/_nav.html.twig' %}

    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h1 class="h3 mb-3">{{ 'demo.home.title'|trans }}</h1>
                        <p class="text-muted mb-4">
                            {{ 'demo.home.lead'|trans({
                                '%table%': 'demo_nowo_cookie_consent_log',
                                '%prefix%': 'table_prefix',
                            }) }}
                        </p>

                        {% include 'demo/_home_content.html.twig' %}

                        {% for label, messages in app.flashes %}
                            {% for message in messages %}
                                <div class="alert alert-{{ label == 'success' ? 'success' : label }} mt-4 mb-0" role="alert">
                                    {{ message }}
                                </div>
                            {% endfor %}
                        {% endfor %}

                        <form method="post" action="{{ demo_route.path('demo_reset_consent') }}" class="d-flex flex-wrap gap-2 align-items-center mt-4">
                            <button type="submit" class="btn btn-outline-danger">
                                {{ 'demo.home.reset'|trans }}
                            </button>
                            <span class="small text-muted">{{ 'demo.home.reset_help'|trans }}</span>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
