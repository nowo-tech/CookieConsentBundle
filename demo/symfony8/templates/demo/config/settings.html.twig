{% extends 'base.html.twig' %}
{% import 'demo/_routes.html.twig' as demo_route %}

{% block title %}{{ 'demo.config.settings.title'|trans }}{% endblock %}

{% block body %}
    {% include 'demo/_nav.html.twig' %}

    <main class="container pb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body p-4">
                        <h1 class="h4 mb-2">
                            {% if is_new_profile|default(false) %}
                                {{ 'demo.config.new_profile'|trans }}
                            {% else %}
                                {{ 'demo.config.settings.title'|trans }} — {{ config.displayName }}
                            {% endif %}
                        </h1>
                        <p class="text-muted mb-4">{{ 'demo.config.settings.lead_profiles'|trans }}</p>

                        {% form_theme form with ['bootstrap_5_layout.html.twig'] %}
                        {{ form_start(form) }}
                            <section class="border rounded-3 p-3 p-md-4 mb-4">
                                <h2 class="h6 text-uppercase text-muted fw-semibold mb-1">{{ 'demo.config.settings.section.profile'|trans }}</h2>
                                <p class="small text-muted mb-3">{{ 'demo.config.settings.section.profile_lead'|trans }}</p>
                                {{ form_row(form.enabled) }}
                                {{ form_row(form.name) }}
                                {{ form_row(form.routePatternsText) }}
                                {{ form_row(form.priority) }}
                                {{ form_row(form.default) }}
                            </section>

                            <section class="border rounded-3 p-3 p-md-4 mb-4">
                                <h2 class="h6 text-uppercase text-muted fw-semibold mb-1">{{ 'demo.config.settings.section.behavior'|trans }}</h2>
                                <p class="small text-muted mb-3">{{ 'demo.config.settings.section.behavior_lead'|trans }}</p>
                                {{ form_row(form.autoShow) }}
                                {{ form_row(form.revision) }}
                                {{ form_row(form.manageScriptTags) }}
                                {{ form_row(form.autoClearCookies) }}
                                {{ form_row(form.hideFromBots) }}
                                {{ form_row(form.disablePageInteraction) }}
                                {{ form_row(form.lazyHtmlGeneration) }}
                                {{ form_row(form.manageIframePlaceholders) }}
                                {{ form_row(form.granularCookieSelection) }}
                                {{ form_row(form.preferencesBubbleEnabled) }}
                                {{ form_row(form.preferencesBubblePosition) }}
                            </section>

                            <section class="border rounded-3 p-3 p-md-4 mb-4">
                                <h2 class="h6 text-uppercase text-muted fw-semibold mb-1">{{ 'demo.config.settings.section.appearance'|trans }}</h2>
                                <p class="small text-muted mb-3">{{ 'demo.config.settings.section.appearance_lead'|trans }}</p>
                                {{ form_row(form.colorTheme) }}
                                {{ form_row(form.darkModeEnabled) }}
                                {{ form_row(form.disableTransitions) }}
                                {{ form_row(form.twoStepModal) }}
                                {{ form_row(form.openPreferencesModal) }}
                            </section>

                            <section class="border rounded-3 p-3 p-md-4 mb-4">
                                <h2 class="h6 text-uppercase text-muted fw-semibold mb-1">{{ 'demo.config.settings.section.consent_modal'|trans }}</h2>
                                <p class="small text-muted mb-3">{{ 'demo.config.settings.section.consent_modal_lead'|trans }}</p>
                                {{ form_row(form.consentModalLayout) }}
                                {{ form_row(form.consentModalVariant) }}
                                {{ form_row(form.consentModalPositionY) }}
                                {{ form_row(form.consentModalPositionX) }}
                                {{ form_row(form.consentModalEqualWeightButtons) }}
                                {{ form_row(form.consentModalFlipButtons) }}
                            </section>

                            <section class="border rounded-3 p-3 p-md-4 mb-4">
                                <h2 class="h6 text-uppercase text-muted fw-semibold mb-1">{{ 'demo.config.settings.section.preferences_modal'|trans }}</h2>
                                <p class="small text-muted mb-3">{{ 'demo.config.settings.section.preferences_modal_lead'|trans }}</p>
                                {{ form_row(form.preferencesModalLayout) }}
                                {{ form_row(form.preferencesModalVariant) }}
                                {{ form_row(form.preferencesModalPositionY) }}
                                {{ form_row(form.preferencesModalPositionX) }}
                                {{ form_row(form.preferencesModalEqualWeightButtons) }}
                                {{ form_row(form.preferencesModalFlipButtons) }}
                            </section>

                            <section class="border rounded-3 p-3 p-md-4 mb-4">
                                <h2 class="h6 text-uppercase text-muted fw-semibold mb-1">{{ 'demo.config.settings.section.route_targeting'|trans }}</h2>
                                <p class="small text-muted mb-3">{{ 'demo.config.settings.section.route_targeting_lead'|trans }}</p>
                                {{ form_row(form.autoShowRouteMode) }}
                                {{ form_row(form.autoShowRoutesText) }}
                            </section>

                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">{{ 'demo.config.settings.save'|trans }}</button>
                                <a href="{{ demo_route.path('demo_cookie_consent_config_index') }}" class="btn btn-outline-secondary">{{ 'demo.config.form.cancel'|trans }}</a>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
