{
    "name": "nowo-tech/cookie-consent-demo-symfony8-tailwind",
    "description": "Tailwind UI demo for Cookie Consent Bundle - Symfony 8.1",
    "type": "project",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=8.4.1,<8.6",
        "doctrine/doctrine-bundle": "^3.2",
        "doctrine/doctrine-migrations-bundle": "^3.3",
        "doctrine/orm": "^3.4",
        "nowo-tech/cookie-consent-bundle": "dev-master as 1.0.99",
        "symfony/asset": "^8.1",
        "symfony/console": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/flex": "^2.0",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/runtime": "^8.1",
        "symfony/security-csrf": "8.1.*",
        "symfony/translation": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/validator": "^8.1",
        "symfony/web-profiler-bundle": "^8.1",
        "symfony/yaml": "^8.1"
    },
    "require-dev": {
        "nowo-tech/twig-inspector-bundle": "@dev",
        "phpunit/phpunit": "^10.0",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "symfony/debug-bundle": "^8.1"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true,
        "audit": {
            "block-insecure": false
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "App\\Demo\\": "shared/Demo/",
            "App\\Command\\": ["src/Command/", "shared/Command/"]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-html coverage --coverage-clover coverage.xml",
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.1.*"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "/var/cookie-consent-bundle",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "path",
            "url": "/var/twig-inspector-bundle",
            "options": {
                "symlink": true
            }
        }
    ]
}
