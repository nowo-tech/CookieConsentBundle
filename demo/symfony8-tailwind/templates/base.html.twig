<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Cookie Consent Demo (Tailwind){% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🍪</text></svg>">
        <script src="https://cdn.tailwindcss.com"></script>
        {% block stylesheets %}{% endblock %}
    </head>
    <body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
        {% block body %}{% endblock %}

        {% if nowo_cookie_consent_should_embed_modal() %}
            {{ render(path('nowo_cookie_consent.show_if_not_set')) }}
        {% endif %}

        {% include '@NowoCookieConsentBundle/_diagnostics_script.html.twig' %}

        {% block javascripts %}{% endblock %}
    </body>
</html>
