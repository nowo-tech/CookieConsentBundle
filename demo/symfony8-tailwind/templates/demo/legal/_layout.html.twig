{% import 'demo/_routes.html.twig' as demo_route %}

{% include 'demo/_nav.html.twig' %}

<main class="mx-auto max-w-3xl px-4 py-10">
    <article class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <div class="p-6 md:p-8">
            <p class="mb-2 text-xs text-slate-500">{{ 'demo.legal.updated'|trans }}</p>
            <h1 class="mb-6 text-2xl font-semibold text-slate-900">{{ title|trans }}</h1>

            {% for section in sections %}
                <section class="mb-6">
                    <h2 class="text-lg font-semibold text-slate-900">{{ section.title|trans }}</h2>
                    <p class="mt-2 text-sm text-slate-600">{{ section.body|trans }}</p>
                </section>
            {% endfor %}

            {% if show_inventory|default(false) %}
                {% include 'demo/legal/_cookie_inventory.html.twig' %}
            {% endif %}

            <hr class="my-6 border-slate-200">

            <nav aria-label="{{ 'demo.legal.related'|trans }}" class="flex flex-wrap gap-2">
                <a class="inline-flex rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" href="{{ demo_route.path('demo_privacy_policy') }}">
                    {{ 'demo.nav.privacy'|trans }}
                </a>
                <a class="inline-flex rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" href="{{ demo_route.path('demo_cookie_policy') }}">
                    {{ 'demo.nav.cookies'|trans }}
                </a>
                <a class="inline-flex rounded-md border border-slate-300 px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" href="{{ demo_route.path('demo_consent_information') }}">
                    {{ 'demo.nav.consent'|trans }}
                </a>
                <button type="button" class="inline-flex rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-semibold text-white hover:bg-indigo-500" data-cc="show-preferencesModal">
                    {{ 'nowo_cookie_consent.manage_link'|trans({}, 'NowoCookieConsentBundle') }}
                </button>
            </nav>
        </div>
    </article>
</main>
