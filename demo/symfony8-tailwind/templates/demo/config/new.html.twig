{% extends 'base.html.twig' %}

{% block title %}{{ 'demo.config.new.title'|trans }}{% endblock %}

{% block body %}
    {% include 'demo/_nav.html.twig' %}

    <main class="mx-auto max-w-3xl px-4 pb-10">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h1 class="text-xl font-semibold text-slate-900">{{ 'demo.config.new.title'|trans }} — {{ config.displayName }}</h1>
            <div class="mt-6">
                {% include 'demo/config/_form.html.twig' with { submit_label: 'demo.config.form.create'|trans } %}
            </div>
        </div>
    </main>
{% endblock %}
