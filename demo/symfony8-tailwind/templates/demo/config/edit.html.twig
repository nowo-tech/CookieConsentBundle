{% extends 'base.html.twig' %}

{% block title %}{{ 'demo.config.edit.title'|trans({'%locale%': translation.locale}) }}{% endblock %}

{% block body %}
    {% include 'demo/_nav.html.twig' %}

    <main class="mx-auto max-w-3xl px-4 pb-10">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h1 class="text-xl font-semibold text-slate-900">{{ 'demo.config.edit.title'|trans({'%locale%': translation.locale}) }}</h1>
            <div class="mt-6">
                {% include 'demo/config/_form.html.twig' with { submit_label: 'demo.config.form.save'|trans } %}
            </div>
        </div>
    </main>
{% endblock %}
