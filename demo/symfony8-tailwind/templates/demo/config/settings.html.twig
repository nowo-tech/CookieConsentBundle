{% extends 'base.html.twig' %}
{% import 'demo/_routes.html.twig' as demo_route %}

{% block title %}{{ 'demo.config.settings.title'|trans }}{% endblock %}

{% block body %}
    {% include 'demo/_nav.html.twig' %}

    <main class="mx-auto max-w-3xl px-4 pb-10">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h1 class="text-xl font-semibold text-slate-900">
                {% if is_new_profile|default(false) %}
                    {{ 'demo.config.new_profile'|trans }}
                {% else %}
                    {{ 'demo.config.settings.title'|trans }} — {{ config.displayName }}
                {% endif %}
            </h1>
            <p class="mt-2 text-sm text-slate-600">{{ 'demo.config.settings.lead_profiles'|trans }}</p>

            {{ form_start(form, {attr: {class: 'mt-6 space-y-4'}}) }}
                {{ form_row(form.enabled) }}
                {{ form_row(form.name) }}
                {{ form_row(form.routePatternsText) }}
                {{ form_row(form.priority) }}
                {{ form_row(form.default) }}
                {{ form_row(form.autoShow) }}
                {{ form_row(form.revision) }}
                {{ form_row(form.manageScriptTags) }}
                {{ form_row(form.autoClearCookies) }}
                {{ form_row(form.hideFromBots) }}
                {{ form_row(form.disablePageInteraction) }}
                {{ form_row(form.lazyHtmlGeneration) }}
                {{ form_row(form.consentModalLayout) }}
                {{ form_row(form.consentModalVariant) }}
                {{ form_row(form.consentModalPositionY) }}
                {{ form_row(form.consentModalPositionX) }}
                {{ form_row(form.consentModalEqualWeightButtons) }}
                {{ form_row(form.consentModalFlipButtons) }}
                {{ form_row(form.autoShowRouteMode) }}
                {{ form_row(form.autoShowRoutesText) }}

                <div class="flex flex-wrap gap-2 pt-2">
                    <button type="submit" class="inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">{{ 'demo.config.settings.save'|trans }}</button>
                    <a href="{{ demo_route.path('demo_cookie_consent_config_index') }}" class="inline-flex rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">{{ 'demo.config.form.cancel'|trans }}</a>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
{% endblock %}
