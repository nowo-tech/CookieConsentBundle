{% extends 'base.html.twig' %}
{% import 'demo/_routes.html.twig' as demo_route %}

{% block title %}{{ 'demo.config.settings.title'|trans }}{% endblock %}

{% block body %}
    {% include 'demo/_nav.html.twig' %}

    <main class="mx-auto max-w-3xl px-4 pb-10">
        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <h1 class="text-xl font-semibold text-slate-900">
                {% if is_new_profile|default(false) %}
                    {{ 'demo.config.new_profile'|trans }}
                {% else %}
                    {{ 'demo.config.settings.title'|trans }} — {{ config.displayName }}
                {% endif %}
            </h1>
            <p class="mt-2 text-sm text-slate-600">{{ 'demo.config.settings.lead_profiles'|trans }}</p>

            {{ form_start(form, {attr: {class: 'mt-6 space-y-6'}}) }}
                <section class="rounded-lg border border-slate-200 bg-slate-50/60 p-4 space-y-4">
                    <div>
                        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">{{ 'demo.config.settings.section.profile'|trans }}</h2>
                        <p class="mt-1 text-sm text-slate-500">{{ 'demo.config.settings.section.profile_lead'|trans }}</p>
                    </div>
                    {{ form_row(form.enabled) }}
                    {{ form_row(form.name) }}
                    {{ form_row(form.routePatternsText) }}
                    {{ form_row(form.priority) }}
                    {{ form_row(form.default) }}
                </section>

                <section class="rounded-lg border border-slate-200 bg-slate-50/60 p-4 space-y-4">
                    <div>
                        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">{{ 'demo.config.settings.section.behavior'|trans }}</h2>
                        <p class="mt-1 text-sm text-slate-500">{{ 'demo.config.settings.section.behavior_lead'|trans }}</p>
                    </div>
                    {{ form_row(form.autoShow) }}
                    {{ form_row(form.revision) }}
                    {{ form_row(form.manageScriptTags) }}
                    {{ form_row(form.autoClearCookies) }}
                    {{ form_row(form.hideFromBots) }}
                    {{ form_row(form.disablePageInteraction) }}
                    {{ form_row(form.lazyHtmlGeneration) }}
                    {{ form_row(form.manageIframePlaceholders) }}
                    {{ form_row(form.granularCookieSelection) }}
                    {{ form_row(form.preferencesBubbleEnabled) }}
                    {{ form_row(form.preferencesBubblePosition) }}
                </section>

                <section class="rounded-lg border border-slate-200 bg-slate-50/60 p-4 space-y-4">
                    <div>
                        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">{{ 'demo.config.settings.section.appearance'|trans }}</h2>
                        <p class="mt-1 text-sm text-slate-500">{{ 'demo.config.settings.section.appearance_lead'|trans }}</p>
                    </div>
                    {{ form_row(form.colorTheme) }}
                    {{ form_row(form.darkModeEnabled) }}
                    {{ form_row(form.disableTransitions) }}
                    {{ form_row(form.twoStepModal) }}
                    {{ form_row(form.openPreferencesModal) }}
                </section>

                <section class="rounded-lg border border-slate-200 bg-slate-50/60 p-4 space-y-4">
                    <div>
                        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">{{ 'demo.config.settings.section.consent_modal'|trans }}</h2>
                        <p class="mt-1 text-sm text-slate-500">{{ 'demo.config.settings.section.consent_modal_lead'|trans }}</p>
                    </div>
                    {{ form_row(form.consentModalLayout) }}
                    {{ form_row(form.consentModalVariant) }}
                    {{ form_row(form.consentModalPositionY) }}
                    {{ form_row(form.consentModalPositionX) }}
                    {{ form_row(form.consentModalEqualWeightButtons) }}
                    {{ form_row(form.consentModalFlipButtons) }}
                </section>

                <section class="rounded-lg border border-slate-200 bg-slate-50/60 p-4 space-y-4">
                    <div>
                        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">{{ 'demo.config.settings.section.preferences_modal'|trans }}</h2>
                        <p class="mt-1 text-sm text-slate-500">{{ 'demo.config.settings.section.preferences_modal_lead'|trans }}</p>
                    </div>
                    {{ form_row(form.preferencesModalLayout) }}
                    {{ form_row(form.preferencesModalVariant) }}
                    {{ form_row(form.preferencesModalPositionY) }}
                    {{ form_row(form.preferencesModalPositionX) }}
                    {{ form_row(form.preferencesModalEqualWeightButtons) }}
                    {{ form_row(form.preferencesModalFlipButtons) }}
                </section>

                <section class="rounded-lg border border-slate-200 bg-slate-50/60 p-4 space-y-4">
                    <div>
                        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">{{ 'demo.config.settings.section.route_targeting'|trans }}</h2>
                        <p class="mt-1 text-sm text-slate-500">{{ 'demo.config.settings.section.route_targeting_lead'|trans }}</p>
                    </div>
                    {{ form_row(form.autoShowRouteMode) }}
                    {{ form_row(form.autoShowRoutesText) }}
                </section>

                <div class="flex flex-wrap gap-2 pt-2">
                    <button type="submit" class="inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">{{ 'demo.config.settings.save'|trans }}</button>
                    <a href="{{ demo_route.path('demo_cookie_consent_config_index') }}" class="inline-flex rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">{{ 'demo.config.form.cancel'|trans }}</a>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
{% endblock %}
