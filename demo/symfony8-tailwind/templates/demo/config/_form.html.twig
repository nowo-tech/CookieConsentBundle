{% import 'demo/_routes.html.twig' as demo_route %}
{{ form_start(form, {attr: {class: 'space-y-4'}}) }}
    {{ form_row(form.locale) }}
    {{ form_row(form.consentModalTitle) }}
    {{ form_row(form.consentModalDescription) }}
    {{ form_row(form.consentModalFooter) }}
    {{ form_row(form.consentModalAcceptAllBtn) }}
    {{ form_row(form.consentModalAcceptNecessaryBtn) }}
    {{ form_row(form.preferencesModalSavePreferencesBtn) }}
    {{ form_row(form.privacyRoute) }}

    <div class="flex flex-wrap gap-2 pt-2">
        <button type="submit" class="inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">{{ submit_label|default('Save') }}</button>
        <a href="{{ demo_route.path('demo_cookie_consent_config_index') }}" class="inline-flex rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">{{ 'demo.config.form.cancel'|trans }}</a>
    </div>
{{ form_end(form) }}
