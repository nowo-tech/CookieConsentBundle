{% extends 'base.html.twig' %}
{% import 'demo/_routes.html.twig' as demo_route %}

{% block title %}{{ 'demo.home.title'|trans }}{% endblock %}

{% block body %}
    {% include 'demo/_nav.html.twig' %}

    <main class="mx-auto max-w-3xl px-4 py-10">
        <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
            <div class="p-6">
                <h1 class="text-2xl font-semibold text-slate-900">{{ 'demo.home.title'|trans }}</h1>
                <p class="mt-3 text-sm text-slate-600">
                    {{ 'demo.home.lead'|trans({
                        '%table%': 'demo_tailwind_nowo_cookie_consent_log',
                        '%prefix%': 'table_prefix',
                    }) }}
                </p>

                <ul class="mt-6 divide-y divide-slate-200 rounded-lg border border-slate-200">
                    <li class="flex items-center justify-between px-4 py-3 text-sm">
                        <span>{{ 'demo.home.consent_saved'|trans }}</span>
                        <span class="rounded-full px-2.5 py-0.5 text-xs font-medium {{ nowo_cookie_consent_is_saved() ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800' }}">
                            {{ nowo_cookie_consent_is_saved() ? 'demo.home.yes'|trans : 'demo.home.no'|trans }}
                        </span>
                    </li>
                    <li class="flex items-center justify-between px-4 py-3 text-sm">
                        <span>{{ 'demo.home.analytics_allowed'|trans }}</span>
                        <span class="rounded-full px-2.5 py-0.5 text-xs font-medium {{ nowo_cookie_consent_is_category_allowed('analytics') ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-600' }}">
                            {{ nowo_cookie_consent_is_category_allowed('analytics') ? 'demo.home.yes'|trans : 'demo.home.no'|trans }}
                        </span>
                    </li>
                    <li class="flex items-center justify-between px-4 py-3 text-sm">
                        <span>{{ 'demo.home.marketing_allowed'|trans }}</span>
                        <span class="rounded-full px-2.5 py-0.5 text-xs font-medium {{ nowo_cookie_consent_is_category_allowed('marketing') ? 'bg-emerald-100 text-emerald-800' : 'bg-slate-100 text-slate-600' }}">
                            {{ nowo_cookie_consent_is_category_allowed('marketing') ? 'demo.home.yes'|trans : 'demo.home.no'|trans }}
                        </span>
                    </li>
                </ul>

                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="mt-4 rounded-lg border px-4 py-3 text-sm {{ label == 'success' ? 'border-emerald-200 bg-emerald-50 text-emerald-800' : 'border-slate-200 bg-slate-50 text-slate-700' }}" role="alert">
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}

                <form method="post" action="{{ demo_route.path('demo_reset_consent') }}" class="mt-6 flex flex-wrap items-center gap-3">
                    <button type="submit" class="inline-flex items-center rounded-md border border-rose-300 bg-white px-4 py-2 text-sm font-semibold text-rose-700 shadow-sm hover:bg-rose-50">
                        {{ 'demo.home.reset'|trans }}
                    </button>
                    <span class="text-xs text-slate-500">{{ 'demo.home.reset_help'|trans }}</span>
                </form>
            </div>
        </div>
    </main>
{% endblock %}
