{% extends 'base.html.twig' %}
{% import 'demo/_routes.html.twig' as demo_route %}
{% form_theme form with ['bootstrap_5_layout.html.twig'] %}

{% block title %}{{ isNew ? 'demo.cookies.new_title'|trans : 'demo.cookies.edit_title'|trans({'%name%': definition.name}) }}{% endblock %}

{% block body %}
    {% include 'demo/_nav.html.twig' %}

    <main class="mx-auto max-w-4xl px-4 pb-10">
        <div class="mb-6">
            <h1 class="text-xl font-semibold text-slate-900">{{ isNew ? 'demo.cookies.new_title'|trans : 'demo.cookies.edit_title'|trans({'%name%': definition.name}) }}</h1>
            <p class="mt-1 text-sm text-slate-600">{{ 'demo.cookies.form_lead'|trans({'%profile%': config.displayName}) }}</p>
        </div>

        <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            {{ form_start(form, {attr: {class: 'space-y-4'}}) }}
                <div class="grid gap-4 md:grid-cols-2">
                    {{ form_row(form.name) }}
                    {{ form_row(form.duration) }}
                </div>
                <div class="grid gap-4 md:grid-cols-3">
                    {{ form_row(form.category) }}
                    {{ form_row(form.type) }}
                    {{ form_row(form.sortOrder) }}
                </div>
                {{ form_row(form.allowedByDefault) }}

                <div class="border-t border-slate-200 pt-4">
                    <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-700">{{ 'demo.cookies.fields.translations'|trans }}</h2>
                    <p class="mt-1 text-sm text-slate-500">{{ 'demo.cookies.translations_lead'|trans }}</p>
                    <div class="mt-3">{% include 'demo/cookies/_translation_tabs.html.twig' %}</div>
                </div>

                <div class="flex flex-wrap gap-2 pt-2">
                    <button type="submit" class="inline-flex rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">{{ 'demo.cookies.save'|trans }}</button>
                    <a class="inline-flex rounded-md border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" href="{{ demo_route.path('demo_cookie_consent_cookies_index', { configId: config.id }) }}">{{ 'demo.config.form.cancel'|trans }}</a>
                </div>
            {{ form_end(form) }}
        </div>
    </main>
{% endblock %}
