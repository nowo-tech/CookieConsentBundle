{% set tabsId = 'cookie-definition-translations-' ~ (definition.id ?? 'new') %}
{% set tabActiveLocale = translationTabLocale|default(constant('App\\Demo\\DemoLocale::DEFAULT')) %}

<div class="cookie-translation-tabs" data-cookie-translation-tabs>
    <div class="flex flex-wrap gap-1 border-b border-slate-200" role="tablist" aria-label="{{ 'demo.cookies.fields.translations'|trans }}">
        {% for locale in constant('App\\Demo\\DemoLocale::ALL') %}
            {% for translationForm in form.translations %}
                {% set entryLocale = translationForm.vars.value.locale|default(translationForm.locale.vars.value)|default('') %}
                {% if entryLocale == locale %}
                    {% set isActive = locale == tabActiveLocale %}
                    <button type="button"
                            class="cookie-translation-tabs__tab -mb-px rounded-t-md border px-3 py-2 text-sm font-medium transition {{ isActive ? 'border-slate-200 border-b-white bg-white text-indigo-700' : 'border-transparent text-slate-600 hover:border-slate-200 hover:text-slate-900' }}"
                            role="tab"
                            aria-selected="{{ isActive ? 'true' : 'false' }}"
                            aria-controls="{{ tabsId }}-{{ locale }}"
                            data-cookie-translation-tab="{{ locale }}"
                            id="{{ tabsId }}-{{ locale }}-tab">
                        {{ locale|upper }}
                    </button>
                {% endif %}
            {% endfor %}
        {% endfor %}
    </div>

    <div class="rounded-b-lg border border-t-0 border-slate-200 bg-white p-4">
        {% for locale in constant('App\\Demo\\DemoLocale::ALL') %}
            {% for translationForm in form.translations %}
                {% set entryLocale = translationForm.vars.value.locale|default(translationForm.locale.vars.value)|default('') %}
                {% if entryLocale == locale %}
                    {% set isActive = locale == tabActiveLocale %}
                    <div class="cookie-translation-tabs__panel space-y-4{% if not isActive %} hidden{% endif %}"
                         role="tabpanel"
                         aria-labelledby="{{ tabsId }}-{{ locale }}-tab"
                         id="{{ tabsId }}-{{ locale }}"
                         data-cookie-translation-panel="{{ locale }}"
                         {% if not isActive %}hidden{% endif %}>
                        <div class="hidden">
                            {{ form_widget(translationForm.locale) }}
                        </div>
                        {{ form_row(translationForm.provider) }}
                        {{ form_row(translationForm.purpose) }}
                    </div>
                {% endif %}
            {% endfor %}
        {% endfor %}
    </div>
</div>

{{ form_errors(form.translations) }}

<script>
(function () {
    document.querySelectorAll('[data-cookie-translation-tabs]').forEach(function (root) {
        var tabs = root.querySelectorAll('[data-cookie-translation-tab]');
        var panels = root.querySelectorAll('[data-cookie-translation-panel]');

        tabs.forEach(function (tab) {
            tab.addEventListener('click', function () {
                var locale = tab.getAttribute('data-cookie-translation-tab');

                tabs.forEach(function (item) {
                    var active = item === tab;
                    item.setAttribute('aria-selected', active ? 'true' : 'false');
                    item.classList.toggle('border-slate-200', active);
                    item.classList.toggle('border-b-white', active);
                    item.classList.toggle('bg-white', active);
                    item.classList.toggle('text-indigo-700', active);
                    item.classList.toggle('border-transparent', !active);
                    item.classList.toggle('text-slate-600', !active);
                });

                panels.forEach(function (panel) {
                    var show = panel.getAttribute('data-cookie-translation-panel') === locale;
                    panel.classList.toggle('hidden', !show);
                    panel.hidden = !show;
                });
            });
        });
    });
})();
</script>
